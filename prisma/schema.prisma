generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String             @id @default(cuid())
  email       String             @unique
  name        String?
  password    String
  role        String             @default("admin")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  protocols   CleaningProtocol[]
  crmCustomer Customer?
}

model CleaningProtocol {
  id         String         @id @default(cuid())
  customerId String
  customer   User           @relation(fields: [customerId], references: [id])
  date       DateTime
  type       String
  location   String
  duration   String?
  staff      String?
  notes      String?
  status     String         @default("abgeschlossen")
  tasks      String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  objectId   String?
  object     ServiceObject? @relation(fields: [objectId], references: [id])
}

model Customer {
  id             String            @id @default(cuid())
  customerNumber String            @unique
  company        String?
  name           String
  email          String?
  phone          String?
  street         String?
  zip            String?
  city           String?
  billingAddress String?
  taxNumber      String?
  vatId          String?
  paymentTerms   String            @default("14 Tage netto")
  notes          String?
  status         String            @default("aktiv")
  portalUserId   String?           @unique
  portalUser     User?             @relation(fields: [portalUserId], references: [id])
  contacts       CustomerContact[]
  objects        ServiceObject[]
  calculations   Calculation[]
  offers         Offer[]
  contracts      Contract[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  role       String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ServiceObject {
  id               String              @id @default(cuid())
  objectNumber     String              @unique
  customerId       String
  customer         Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name             String
  objectType       String?
  street           String
  zip              String
  city             String
  areaSqm          Float?
  floors           Int?
  accessDetails    String?
  keyDetails       String?
  serviceWindow    String?
  specialFeatures  String?
  notes            String?
  status           String              @default("aktiv")
  nextQualityCheck DateTime?
  servicePlans     ObjectServicePlan[]
  protocols        CleaningProtocol[]
  calculations     Calculation[]
  offers           Offer[]
  contracts        Contract[]
  documents        ObjectDocument[]
  deadlines        Deadline[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model ObjectServicePlan {
  id           String        @id @default(cuid())
  objectId     String
  object       ServiceObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  serviceKey   String
  title        String
  frequency    String?
  unit         String?
  quantity     Float?
  tasks        String
  instructions String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Calculation {
  id                  String         @id @default(cuid())
  calculationNumber   String         @unique
  customerId          String?
  customer            Customer?      @relation(fields: [customerId], references: [id])
  objectId            String?
  object              ServiceObject? @relation(fields: [objectId], references: [id])
  title               String
  serviceKey          String
  status              String         @default("entwurf")
  inputSnapshot       String
  resultSnapshot      String
  netTotal            Float
  grossTotal          Float
  productiveHours     Float
  effectiveHourlyRate Float
  marginPercent       Float
  overrideReason      String?
  offers              Offer[]
  contracts           Contract[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model Offer {
  id            String            @id @default(cuid())
  offerNumber   String            @unique
  customerId    String
  customer      Customer          @relation(fields: [customerId], references: [id])
  objectId      String?
  object        ServiceObject?    @relation(fields: [objectId], references: [id])
  calculationId String?
  calculation   Calculation?      @relation(fields: [calculationId], references: [id])
  title         String
  serviceKey    String
  status        String            @default("entwurf")
  validUntil    DateTime?
  netTotal      Float
  vatRate       Float             @default(19)
  grossTotal    Float
  notes         String?
  versions      DocumentVersion[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Contract {
  id                 String            @id @default(cuid())
  contractNumber     String            @unique
  customerId         String
  customer           Customer          @relation(fields: [customerId], references: [id])
  objectId           String?
  object             ServiceObject?    @relation(fields: [objectId], references: [id])
  calculationId      String?
  calculation        Calculation?      @relation(fields: [calculationId], references: [id])
  title              String
  serviceKey         String
  status             String            @default("entwurf")
  startsAt           DateTime?
  endsAt             DateTime?
  cancellationMonths Int               @default(1)
  noticeMonths       Int               @default(1)
  netMonthly         Float
  vatRate            Float             @default(19)
  grossMonthly       Float
  notes              String?
  versions           DocumentVersion[]
  deadlines          Deadline[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model DocumentVersion {
  id         String    @id @default(cuid())
  offerId    String?
  offer      Offer?    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: Cascade)
  version    Int
  snapshot   String
  status     String    @default("entwurf")
  checksum   String?
  createdAt  DateTime  @default(now())

  @@unique([offerId, version])
  @@unique([contractId, version])
}

model ObjectDocument {
  id             String        @id @default(cuid())
  objectId       String
  object         ServiceObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  documentNumber String        @unique
  type           String
  title          String
  serviceKey     String?
  status         String        @default("entwurf")
  snapshot       String
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model DocumentTemplate {
  id            String   @id @default(cuid())
  key           String   @unique
  category      String
  serviceKey    String?
  title         String
  description   String?
  content       String
  legalApproved Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CommunicationTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  subject   String
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deadline {
  id         String         @id @default(cuid())
  objectId   String?
  object     ServiceObject? @relation(fields: [objectId], references: [id], onDelete: Cascade)
  contractId String?
  contract   Contract?      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  title      String
  type       String
  dueAt      DateTime
  status     String         @default("offen")
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model MaterialItem {
  id              String   @id @default(cuid())
  sku             String?  @unique
  name            String
  category        String?
  unit            String   @default("Stück")
  stock           Float    @default(0)
  minimumStock    Float    @default(0)
  unitCost        Float    @default(0)
  storageLocation String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EquipmentItem {
  id              String    @id @default(cuid())
  inventoryNumber String    @unique
  name            String
  category        String?
  manufacturer    String?
  model           String?
  serialNumber    String?
  purchaseDate    DateTime?
  nextMaintenance DateTime?
  status          String    @default("einsatzbereit")
  location        String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ServicePriceSetting {
  id                   String   @id @default(cuid())
  serviceKey           String   @unique
  title                String
  unit                 String
  performancePerHour   Float
  wagePerHour          Float    @default(15)
  payrollBurdenPercent Float    @default(75)
  materialPercent      Float    @default(8)
  equipmentFlat        Float    @default(0)
  setupMinutes         Int      @default(15)
  minimumHourlyRate    Float    @default(38)
  targetHourlyRate     Float    @default(42)
  minimumMarginPercent Float    @default(20)
  publicRangePercent   Float    @default(12)
  sourceNote           String?
  effectiveFrom        DateTime?
  reviewedAt           DateTime?
  version              Int      @default(1)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model DownloadLead {
  id          String   @id @default(cuid())
  name        String
  company     String?
  email       String
  documentKey String
  source      String?
  newsletter  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String   @default("neu") // neu | in_bearbeitung | kontaktiert | erledigt
  mailSent  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuoteRequest {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String?
  company      String?
  service      String
  area         String?
  frequency    String?
  estimatedMin Int?
  estimatedMax Int?
  message      String?
  status       String   @default("neu") // neu | in_bearbeitung | kontaktiert | erledigt
  mailSent     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String
  content       String
  coverImage    String?
  author        String   @default("Huwa Team")
  category      String   @default("Reinigung")
  metaTitle     String?
  metaDesc      String?
  published     Boolean  @default(true)
  publishedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  aiGenerated   Boolean  @default(false)
  aiPrompt      String?
  targetKeyword String?
  targetCity    String?
  targetService String?
  contentStatus String   @default("draft")
}

model SocialPost {
  id          String    @id @default(cuid())
  platform    String
  type        String
  status      String    @default("draft")
  caption     String
  hashtags    String?
  imageUrl    String?
  mediaUrls   String?
  scheduledAt DateTime?
  publishedAt DateTime?
  externalId  String?
  error       String?
  blogPostId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SocialAccount {
  id             String    @id @default(cuid())
  platform       String
  accountId      String
  username       String?
  accessToken    String
  tokenExpiresAt DateTime?
  status         String    @default("connected")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  company   String?
  content   String
  rating    Int      @default(5)
  location  String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
