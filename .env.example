# Datenbank
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="bitte-ein-langes-zufaelliges-secret-hier-einsetzen"

# Optionaler Admin-Seed (nur lokal oder bei bewusstem Setup verwenden)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="bitte-ein-eigenes-sehr-langes-passwort-setzen"

# Verschlüsselung für gespeicherte Social/OAuth Tokens
# Muss exakt 32 Bytes sein, z. B. aus: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY="32-byte-base64-secret-hier-einsetzen"

# Site
NEXT_PUBLIC_SITE_URL="https://www.huwa-reinigung.de"

# E-Mail (Nodemailer SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="info@huwa-reinigung.de"
SMTP_PASSWORD="dein-smtp-passwort"
SMTP_FROM="Huwa Gebäudereinigung <info@huwa-reinigung.de>"
CONTACT_EMAIL="info@huwa-reinigung.de"

# WhatsApp (internationales Format ohne +)
NEXT_PUBLIC_PHONE="+49 170 1234567"

# Meta/Instagram OAuth
META_APP_ID=""
META_APP_SECRET=""
